# ─── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=service-account@yourcompany.com
JIRA_API_TOKEN=your_atlassian_api_token_here
JIRA_DEFAULT_BOARD_ID=1
# Story points custom field — common values: customfield_10016, customfield_10028
JIRA_STORY_POINTS_FIELD=customfield_10016

# ─── Microsoft Graph / Azure AD ──────────────────────────────────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your_azure_client_secret_here

# ─── Team ─────────────────────────────────────────────────────────────────────
# Comma-separated M365 UPNs — must match Jira assignee email addresses exactly
TEAM_MEMBER_UPNS=alice@yourcompany.com,bob@yourcompany.com,charlie@yourcompany.com

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
